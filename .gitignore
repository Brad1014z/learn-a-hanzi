# --- Android / Gradle ---
.gradle/
build/
*/build/
captures/
*.apk
*.aab
*.ap_
*.dex

# --- Kotlin / JVM ---
*.class
hs_err_pid*
.kotlin/

# --- Android Studio / IntelliJ ---
.idea/
*.iml
*.iws
*.ipr
out/
.navigation/
local.properties

# --- Keystore (never commit signing keys) ---
*.jks
*.keystore

# --- OS ---
.DS_Store
Thumbs.db

# --- Data pipeline (raw downloads are large / reproducible, not source) ---
data/raw/
data/output/
!data/raw/.gitkeep

# --- Generated SQLite assets (regenerated by :data-ingest) ---
# Keep the directory tracked, ignore ad-hoc binaries — EXCEPT the bundled dataset:
# it is small (<1 MB), byte-deterministic (same inputs → same bytes, verified), and
# committing it keeps a plain checkout (and CI's APK artifact) runnable without the
# ~45 MB raw-source download. Decision 2026-07-10 (M2); revisit if it grows.
*/src/main/assets/databases/*.sqlite
!*/src/main/assets/databases/hanzi_v*.sqlite
!*/src/main/assets/databases/.gitkeep

# --- Logs / profiling ---
*.log
*.hprof
