# --- Android / Gradle ---
.gradle/
build/
*/build/
captures/
*.apk
*.aab
*.ap_
*.dex

# --- Kotlin / JVM ---
*.class
hs_err_pid*

# --- Android Studio / IntelliJ ---
.idea/
*.iml
*.iws
*.ipr
out/
.navigation/
local.properties

# --- Keystore (never commit signing keys) ---
*.jks
*.keystore

# --- OS ---
.DS_Store
Thumbs.db

# --- Data pipeline (raw downloads are large / reproducible, not source) ---
data/raw/
data/output/
!data/raw/.gitkeep

# --- Generated SQLite assets (regenerated by :data-ingest) ---
# Keep the directory tracked, ignore the binaries.
*/src/main/assets/databases/*.sqlite
!*/src/main/assets/databases/.gitkeep

# --- Logs / profiling ---
*.log
*.hprof
